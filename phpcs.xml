<?xml version="1.0"?>
<ruleset name="WPVDB Smart Search">
	<description>PHPCS ruleset for the WPVDB Smart Search plugin.</description>

	<rule ref="WordPress-Extra" />
	<rule ref="WordPress-Docs" />
	<rule ref="WordPress-VIP-Go">
		<!-- JS/CSS sniffs: we lint JS with ESLint and CSS with Stylelint. These also emit deprecation warnings under phpcs 3.13+. -->
		<exclude name="WordPressVIPMinimum.JS" />
	</rule>

	<rule ref="WordPress">
		<exclude name="Generic.Arrays.DisallowShortArraySyntax.Found" />
		<exclude name="Universal.Arrays.DisallowShortArraySyntax.Found" />
		<exclude name="Universal.Operators.DisallowStandalonePostIncrementDecrement.PostIncrementFound" />
	</rule>
	<rule ref="Generic.Arrays.DisallowLongArraySyntax" />

	<rule ref="PHPCompatibilityWP"/>
	<config name="testVersion" value="8.0-"/>

	<arg name="extensions" value="php"/>

	<!-- Show sniff codes in all reports -->
	<arg value="s"/>

	<file>.</file>

	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/dist/*</exclude-pattern>
	<exclude-pattern>*/release/*</exclude-pattern>
</ruleset>
